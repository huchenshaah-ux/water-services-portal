{
  "version": 2,
  "framework": null,
  "functions": {
    "api/hello.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "api/ping.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "api/index.php": {
      "runtime": "vercel-php@0.6.2",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/hello", "dest": "/api/hello.php" },
    { "src": "/ping", "dest": "/api/ping.php" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(manifest\\.json|sw\\.js)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
