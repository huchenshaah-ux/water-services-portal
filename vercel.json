{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "api/hello.php", "use": "vercel-php@0.7.4" },
    { "src": "api/ping.php", "use": "vercel-php@0.7.4" },
    { "src": "api/index.php", "use": "vercel-php@0.7.4" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/hello", "dest": "/api/hello.php" },
    { "src": "/ping", "dest": "/api/ping.php" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(manifest\\.json|sw\\.js)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
